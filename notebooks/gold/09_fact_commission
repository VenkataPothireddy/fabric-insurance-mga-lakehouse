SELECT 
    COUNT(*) AS total_rows,
    MIN(commission_key) AS min_key,
    MAX(commission_key) AS max_key,
    COUNT(DISTINCT commission_key) AS distinct_keys
FROM fact.commission;


SELECT TOP 5
    commission_key,
    date_key,
    payout_natural_key,
    policy_natural_key,
    commission_rate,
    true_tier_rate,
    program_modifier,
    true_program_modifier,
    commission_amount,
    true_commission_amount,
    payout_status,
    calc_method
FROM fact.commission
ORDER BY commission_key;



-- Pattern A signature in fact.commission (those with both wrong rate AND money moved)
SELECT COUNT(*) AS pattern_a_in_gold
FROM fact.commission
WHERE commission_rate <> true_tier_rate
  AND commission_amount <> true_commission_amount;



-- Pattern B signature
SELECT COUNT(*) AS pattern_b_in_gold
FROM fact.commission
WHERE program_modifier = 1.0 
  AND true_program_modifier <> 1.0
  AND commission_amount <> true_commission_amount;




-- Pattern C signature
SELECT COUNT(*) AS pattern_c_in_gold
FROM fact.commission
WHERE volume_bonus > 0 
  AND true_volume_bonus = 0
  AND commission_amount <> true_commission_amount;




SELECT 
    COUNT(*) AS payout_count,
    SUM(commission_amount) AS total_vba_paid,
    SUM(true_commission_amount) AS total_should_have_paid,
    SUM(commission_amount - true_commission_amount) AS net_drift
FROM fact.commission;




SELECT
    (SELECT COUNT(*) FROM fact.commission f LEFT JOIN dim.date    d  ON f.date_key    = d.date_key    WHERE d.date_key    IS NULL) AS orphan_dates,
    (SELECT COUNT(*) FROM fact.commission f LEFT JOIN dim.policy  p  ON f.policy_key  = p.policy_key  WHERE p.policy_key  IS NULL) AS orphan_policies,
    (SELECT COUNT(*) FROM fact.commission f LEFT JOIN dim.agent   a  ON f.agent_key   = a.agent_key   WHERE a.agent_key   IS NULL) AS orphan_agents,
    (SELECT COUNT(*) FROM fact.commission f LEFT JOIN dim.program pr ON f.program_key = pr.program_key WHERE pr.program_key IS NULL) AS orphan_programs,
    (SELECT COUNT(*) FROM fact.commission f LEFT JOIN dim.carrier c  ON f.carrier_key = c.carrier_key WHERE c.carrier_key IS NULL) AS orphan_carriers;



ALTER TABLE fact.commission 
ADD CONSTRAINT PK_fact_commission PRIMARY KEY NONCLUSTERED (commission_key) NOT ENFORCED;