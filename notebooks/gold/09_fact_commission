/*
================================================================
File:        09_fact_commission.sql
Purpose:     Create and populate fact.commission in gold_citadel_mga
Source:      silver_citadel_mga.dbo.silver_commission_payouts (5,000 rows)
Grain:       One row per commission payout

Notes:
  Widest fact in the warehouse. Carries both legacy VBA values and
  silver-corrected (true_) values side-by-side so drift queries are
  one-line subtractions without self-joins.

  Renames at load:
    silver_effective_rate    -> true_effective_rate
    silver_commission_amount -> true_commission_amount
  Restores symmetry with all other true_-prefixed corrected columns.

  KNOWN GAP: Loaded 4,977 of 5,000 silver payouts. 23 silver payouts
  reference policies that don't exist in silver_policies — a 
  referential integrity gap inside silver itself. Caught at gold load
  via INNER JOIN. Documented rather than papered over.

  Bug pattern counts in this fact (after gap):
    Pattern A (wrong tier rate):              24 rows
    Pattern B (modifier silently 1.0):        38 rows (was 39 in silver)
    Pattern C (volume bonus to non-qualifier): 44 rows
    Total drift rows:                         106 (was 107)

  Headline aggregates:
    Total VBA paid:                $11,457,800.54
    Total should have paid:        $11,470,202.86
    Net drift (underpaid agents):  $12,402.32

Author:      Venkata Pothireddy
================================================================
*/


-- DDL: 26 columns. INT keys, VARCHAR identity/status columns,
-- DECIMAL(5,4) for rates/modifiers, DECIMAL(12,2) for money.
CREATE TABLE fact.commission (
    commission_key              INT             NOT NULL,
    date_key                    INT             NOT NULL,
    policy_key                  INT             NOT NULL,
    agent_key                   INT             NOT NULL,
    program_key                 INT             NOT NULL,
    carrier_key                 INT             NOT NULL,
    payout_natural_key          VARCHAR(20)     NOT NULL,
    policy_natural_key          VARCHAR(20)     NOT NULL,
    premium_amount              DECIMAL(12, 2)  NOT NULL,
    commission_rate             DECIMAL(5, 4)   NOT NULL,
    program_modifier            DECIMAL(5, 4)   NOT NULL,
    volume_bonus                DECIMAL(5, 4)   NOT NULL,
    status_multiplier           DECIMAL(5, 4)   NOT NULL,
    commission_amount           DECIMAL(12, 2)  NOT NULL,
    true_tier_rate              DECIMAL(5, 4)   NOT NULL,
    true_program_modifier       DECIMAL(5, 4)   NOT NULL,
    true_volume_bonus           DECIMAL(5, 4)   NOT NULL,
    true_status_multiplier      DECIMAL(5, 4)   NOT NULL,
    true_effective_rate         DECIMAL(5, 4)   NOT NULL,
    true_commission_amount      DECIMAL(12, 2)  NOT NULL,
    adjustments                 DECIMAL(12, 2)  NOT NULL,
    policy_status               VARCHAR(20)     NOT NULL,
    payout_status               VARCHAR(15)     NOT NULL,
    calc_method                 VARCHAR(20)     NOT NULL,
    created_at                  DATETIME2(6)    NOT NULL,
    updated_at                  DATETIME2(6)    NOT NULL
);


-- Verify the table structure: should return 26 rows, all NOT NULL.
SELECT 
    c.name AS column_name,
    t.name AS data_type,
    c.max_length,
    c.precision,
    c.scale,
    c.is_nullable
FROM sys.columns c
JOIN sys.types t ON c.user_type_id = t.user_type_id
WHERE c.object_id = OBJECT_ID('fact.commission')
ORDER BY c.column_id;


-- Load fact.commission from silver_commission_payouts.
-- Four-table join chain: silver -> dim.policy -> {dim.agent, dim.program, dim.carrier}.
-- agent/program/carrier come through dim.policy because silver_commission_payouts
-- doesn't carry those FKs directly — they're inherited from the parent policy.
-- INNER JOINs intentionally: any payout referencing a missing dim row is dropped
-- and surfaced as a load-time gap rather than silently loading a bad FK.
INSERT INTO fact.commission (
    commission_key,
    date_key,
    policy_key,
    agent_key,
    program_key,
    carrier_key,
    payout_natural_key,
    policy_natural_key,
    premium_amount,
    commission_rate,
    program_modifier,
    volume_bonus,
    status_multiplier,
    commission_amount,
    true_tier_rate,
    true_program_modifier,
    true_volume_bonus,
    true_status_multiplier,
    true_effective_rate,
    true_commission_amount,
    adjustments,
    policy_status,
    payout_status,
    calc_method,
    created_at,
    updated_at
)
SELECT
    ROW_NUMBER() OVER (ORDER BY s.payout_id)                              AS commission_key,
    -- date_key as YYYYMMDD integer, no CAST needed (payout_date already DATE in silver)
    YEAR(s.payout_date) * 10000 
        + MONTH(s.payout_date) * 100 
        + DAY(s.payout_date)                                              AS date_key,
    pol.policy_key                                                        AS policy_key,
    a.agent_key                                                           AS agent_key,
    prog.program_key                                                      AS program_key,
    c.carrier_key                                                         AS carrier_key,
    s.payout_id                                                           AS payout_natural_key,
    s.policy_id                                                           AS policy_natural_key,
    s.premium                                                             AS premium_amount,
    s.commission_rate                                                     AS commission_rate,
    s.program_modifier                                                    AS program_modifier,
    s.volume_bonus                                                        AS volume_bonus,
    s.status_multiplier                                                   AS status_multiplier,
    s.commission_amount                                                   AS commission_amount,
    s.true_tier_rate                                                      AS true_tier_rate,
    s.true_program_modifier                                               AS true_program_modifier,
    s.true_volume_bonus                                                   AS true_volume_bonus,
    s.true_status_multiplier                                              AS true_status_multiplier,
    -- rename silver_ prefix to true_ prefix for consistency with the other corrected values
    s.silver_effective_rate                                               AS true_effective_rate,
    s.silver_commission_amount                                            AS true_commission_amount,
    s.adjustments                                                         AS adjustments,
    s.policy_status                                                       AS policy_status,
    s.payout_status                                                       AS payout_status,
    s.calc_method                                                         AS calc_method,
    SYSDATETIME()                                                         AS created_at,
    SYSDATETIME()                                                         AS updated_at
FROM silver_citadel_mga.dbo.silver_commission_payouts s
JOIN dim.policy   pol  ON s.policy_id      = pol.policy_natural_key
JOIN dim.agent    a    ON pol.agent_id     = a.agent_natural_key
JOIN dim.program  prog ON pol.program_code = prog.program_natural_key
JOIN dim.carrier  c    ON pol.carrier_id   = c.carrier_natural_key
WHERE s.payout_id              IS NOT NULL
  AND s.policy_id              IS NOT NULL
  AND s.payout_date            IS NOT NULL
  AND s.premium                IS NOT NULL
  AND s.commission_rate        IS NOT NULL
  AND s.program_modifier       IS NOT NULL
  AND s.volume_bonus           IS NOT NULL
  AND s.status_multiplier      IS NOT NULL
  AND s.commission_amount      IS NOT NULL
  AND s.true_tier_rate         IS NOT NULL
  AND s.true_program_modifier  IS NOT NULL
  AND s.true_volume_bonus      IS NOT NULL
  AND s.true_status_multiplier IS NOT NULL
  AND s.silver_effective_rate  IS NOT NULL
  AND s.silver_commission_amount IS NOT NULL
  AND s.adjustments            IS NOT NULL
  AND s.policy_status          IS NOT NULL
  AND s.payout_status          IS NOT NULL
  AND s.calc_method            IS NOT NULL;
-- Expected: 5000 rows. Got: 4977. The 23-row gap is investigated below.


-- ================================================================
-- INVESTIGATION: why did we get 4977 instead of 5000?
-- The load reported (4977 records affected) — 23 short of the silver
-- row count. That's an INNER JOIN dropping rows, not a NULL filter.
-- The next three queries trace where the gap actually lives.
-- ================================================================


-- Diagnostic 1: rule out the WHERE clause.
-- Are there silver rows being dropped by the IS NOT NULL filters?
SELECT COUNT(*) AS nulled_rows
FROM silver_citadel_mga.dbo.silver_commission_payouts
WHERE payout_id              IS NULL
   OR policy_id              IS NULL
   OR payout_date            IS NULL
   OR premium                IS NULL
   OR commission_rate        IS NULL
   OR program_modifier       IS NULL
   OR volume_bonus           IS NULL
   OR status_multiplier      IS NULL
   OR commission_amount      IS NULL
   OR true_tier_rate         IS NULL
   OR true_program_modifier  IS NULL
   OR true_volume_bonus      IS NULL
   OR true_status_multiplier IS NULL
   OR silver_effective_rate  IS NULL
   OR silver_commission_amount IS NULL
   OR adjustments            IS NULL
   OR policy_status          IS NULL
   OR payout_status          IS NULL
   OR calc_method            IS NULL;
-- Result: 0. So the WHERE clause didn't drop anything — it's a join issue.


-- Diagnostic 2: find which silver rows failed which join.
-- LEFT JOIN preserves all silver rows, then filter to those where at
-- least one dim FK didn't resolve. The CASE columns label which dim
-- is missing for each row.
SELECT 
    s.payout_id,
    s.policy_id,
    CASE WHEN pol.policy_key  IS NULL THEN 'MISSING_POLICY'   ELSE NULL END AS policy_issue,
    pol.agent_id   AS policy_agent_id,
    pol.program_code AS policy_program_code,
    pol.carrier_id AS policy_carrier_id,
    CASE WHEN a.agent_key    IS NULL AND pol.agent_id    IS NOT NULL THEN 'MISSING_AGENT'   ELSE NULL END AS agent_issue,
    CASE WHEN prog.program_key IS NULL AND pol.program_code IS NOT NULL THEN 'MISSING_PROGRAM' ELSE NULL END AS program_issue,
    CASE WHEN c.carrier_key  IS NULL AND pol.carrier_id  IS NOT NULL THEN 'MISSING_CARRIER' ELSE NULL END AS carrier_issue
FROM silver_citadel_mga.dbo.silver_commission_payouts s
LEFT JOIN dim.policy   pol  ON s.policy_id      = pol.policy_natural_key
LEFT JOIN dim.agent    a    ON pol.agent_id     = a.agent_natural_key
LEFT JOIN dim.program  prog ON pol.program_code = prog.program_natural_key
LEFT JOIN dim.carrier  c    ON pol.carrier_id   = c.carrier_natural_key
WHERE pol.policy_key   IS NULL
   OR a.agent_key      IS NULL
   OR prog.program_key IS NULL
   OR c.carrier_key    IS NULL;
-- Result: 23 rows, every one of them MISSING_POLICY. None of the other
-- dims have orphans. So the gap is at the silver_commission_payouts -> 
-- silver_policies link, not in our gold dim loads.


-- Diagnostic 3: confirm the 23 missing policy_ids don't exist in silver_policies.
-- This rules out "dim.policy didn't load all silver_policies rows."
-- The 23 IDs below are exactly the ones Diagnostic 2 surfaced.
SELECT COUNT(*) AS missing_in_silver_policies
FROM (VALUES 
    ('POL-002534'), ('POL-000699'), ('POL-001486'), ('POL-001138'), ('POL-001464'),
    ('POL-002229'), ('POL-003449'), ('POL-002291'), ('POL-001736'), ('POL-003747'),
    ('POL-007972'), ('POL-005614'), ('POL-003194'), ('POL-005897'), ('POL-004938'),
    ('POL-006436'), ('POL-006103'), ('POL-004258'), ('POL-004070'), ('POL-000078'),
    ('POL-006688'), ('POL-006064'), ('POL-006320')
) AS missing(policy_id)
LEFT JOIN silver_citadel_mga.dbo.silver_policies sp ON missing.policy_id = sp.policy_id
WHERE sp.policy_id IS NULL;
-- Result: 23. Confirmed — these 23 policy_ids don't exist anywhere in
-- silver_policies. The gap is in silver itself, not in our gold load.
-- DECISION: accept the loss, document it, file as a silver DQ issue.
-- Did not regenerate silver or invent placeholder policies.


-- How many of the 107 reconciliation rows reference one of the 23 orphan payouts?
-- This tells us how many drift rows we'll lose when loading 
-- fact.commission_reconciliation next.
SELECT COUNT(*) AS reconciliation_rows_affected
FROM silver_citadel_mga.dbo.silver_commission_reconciliation r
WHERE r.payout_id IN (
    'CMP-0003036', 'CMP-0001765', 'CMP-0000515', 'CMP-0002151', 'CMP-0002618',
    'CMP-0004475', 'CMP-0000352', 'CMP-0003802', 'CMP-0003059', 'CMP-0002161',
    'CMP-0002612', 'CMP-0001629', 'CMP-0001048', 'CMP-0001926', 'CMP-0000244',
    'CMP-0003052', 'CMP-0001816', 'CMP-0003193', 'CMP-0000962', 'CMP-0000802',
    'CMP-0004436', 'CMP-0004443', 'CMP-0000440'
);
-- Result: 1. We'll lose 1 reconciliation row — fact.commission_reconciliation
-- will hold 106 instead of 107.


-- Identify the affected reconciliation row so we know which pattern is impacted.
SELECT 
    r.payout_id,
    r.policy_id,
    r.drift_direction,
    r.drift_pattern,
    r.variance
FROM silver_citadel_mga.dbo.silver_commission_reconciliation r
WHERE r.payout_id IN (
    'CMP-0003036', 'CMP-0001765', 'CMP-0000515', 'CMP-0002151', 'CMP-0002618',
    'CMP-0004475', 'CMP-0000352', 'CMP-0003802', 'CMP-0003059', 'CMP-0002161',
    'CMP-0002612', 'CMP-0001629', 'CMP-0001048', 'CMP-0001926', 'CMP-0000244',
    'CMP-0003052', 'CMP-0001816', 'CMP-0003193', 'CMP-0000962', 'CMP-0000802',
    'CMP-0004436', 'CMP-0004443', 'CMP-0000440'
);
-- Result: CMP-0004443 / POL-006064 / OVERPAYMENT / PATTERN_B / -$82.02.
-- One Pattern B overpayment row dropped. Pattern A (24) and Pattern C (44)
-- are unaffected; Pattern B drops from 39 to 38 in gold.


-- ================================================================
-- VERIFICATION of fact.commission load
-- ================================================================


-- Check 1: row count and key integrity. Expecting 4977 / 1 / 4977 / 4977.
SELECT 
    COUNT(*) AS total_rows,
    MIN(commission_key) AS min_key,
    MAX(commission_key) AS max_key,
    COUNT(DISTINCT commission_key) AS distinct_keys
FROM fact.commission;


-- Check 2: eyeball five sample rows. Most rows have VBA == true (no drift)
-- since only 106 of 4977 have a bug, so don't expect drift in this sample.
SELECT TOP 5
    commission_key,
    date_key,
    payout_natural_key,
    policy_natural_key,
    commission_rate,
    true_tier_rate,
    program_modifier,
    true_program_modifier,
    commission_amount,
    true_commission_amount,
    payout_status,
    calc_method
FROM fact.commission
ORDER BY commission_key;


-- Check 3a: count Pattern A rows in fact directly (wrong tier rate AND money moved).
-- Should match silver's 24.
SELECT COUNT(*) AS pattern_a_in_gold
FROM fact.commission
WHERE commission_rate <> true_tier_rate
  AND commission_amount <> true_commission_amount;


-- Check 3b: Pattern B (modifier silently 1.0 AND money moved).
-- Should be 38, down from silver's 39 (we lost CMP-0004443 to the orphan gap).
SELECT COUNT(*) AS pattern_b_in_gold
FROM fact.commission
WHERE program_modifier = 1.0 
  AND true_program_modifier <> 1.0
  AND commission_amount <> true_commission_amount;


-- Check 3c: Pattern C (volume bonus applied to non-qualifying agent AND money moved).
-- Should match silver's 44.
SELECT COUNT(*) AS pattern_c_in_gold
FROM fact.commission
WHERE volume_bonus > 0 
  AND true_volume_bonus = 0
  AND commission_amount <> true_commission_amount;


-- Check 4: the headline aggregates the demo hinges on.
-- Net drift is small (~$12K underpaid), but the gross is much larger —
-- Pattern A underpays ~$21K, Pattern C overpays ~$9K. The errors cancel
-- in aggregate while persisting per-agent. That's the demo punchline.
SELECT 
    COUNT(*) AS payout_count,
    SUM(commission_amount) AS total_vba_paid,
    SUM(true_commission_amount) AS total_should_have_paid,
    SUM(commission_amount - true_commission_amount) AS net_drift
FROM fact.commission;


-- Check 5: referential integrity. Fabric Warehouse doesn't enforce FKs,
-- so verify zero orphans manually across all five dim relationships.
-- Expected: 0 / 0 / 0 / 0 / 0.
SELECT
    (SELECT COUNT(*) FROM fact.commission f LEFT JOIN dim.date    d  ON f.date_key    = d.date_key    WHERE d.date_key    IS NULL) AS orphan_dates,
    (SELECT COUNT(*) FROM fact.commission f LEFT JOIN dim.policy  p  ON f.policy_key  = p.policy_key  WHERE p.policy_key  IS NULL) AS orphan_policies,
    (SELECT COUNT(*) FROM fact.commission f LEFT JOIN dim.agent   a  ON f.agent_key   = a.agent_key   WHERE a.agent_key   IS NULL) AS orphan_agents,
    (SELECT COUNT(*) FROM fact.commission f LEFT JOIN dim.program pr ON f.program_key = pr.program_key WHERE pr.program_key IS NULL) AS orphan_programs,
    (SELECT COUNT(*) FROM fact.commission f LEFT JOIN dim.carrier c  ON f.carrier_key = c.carrier_key WHERE c.carrier_key IS NULL) AS orphan_carriers;


-- PK constraint: NOT ENFORCED (Fabric requirement). Informational — feeds
-- Power BI semantic model relationship auto-detection and query optimizer.
ALTER TABLE fact.commission 
ADD CONSTRAINT PK_fact_commission PRIMARY KEY NONCLUSTERED (commission_key) NOT ENFORCED;